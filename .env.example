# =============================================================================
# PlotVerse environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values for your Firebase
# project. `.env.local` is git-ignored. Variables prefixed with NEXT_PUBLIC_ are
# inlined into the client bundle (safe to expose); the FIREBASE_ADMIN_* values
# are server-only secrets and must never be exposed to the browser.
# =============================================================================

# -----------------------------------------------------------------------------
# Client (browser) Firebase Web SDK config  ->  lib/firebase/client.ts
# Find these in Firebase Console > Project settings > Your apps > Web app.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional (Analytics):
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# -----------------------------------------------------------------------------
# Firebase Admin (server) service-account credentials  ->  lib/firebase/server.ts
# Generate in Firebase Console > Project settings > Service accounts >
# "Generate new private key". NEVER commit these values.
# The private key is a multi-line PEM; keep the surrounding quotes and the
# literal "\n" sequences — they are normalized to newlines at runtime.
# -----------------------------------------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_LINE_1\nYOUR_KEY_LINE_2\n-----END PRIVATE KEY-----\n"
# Optional; defaults to "<FIREBASE_ADMIN_PROJECT_ID>.appspot.com":
FIREBASE_ADMIN_STORAGE_BUCKET=your-project-id.appspot.com

# -----------------------------------------------------------------------------
# Mapbox GL access token  ->  components/viewer/MapRenderer.tsx
# Create one in Mapbox account > Tokens. This is a NEXT_PUBLIC_ value, so it is
# inlined into the client bundle and IS exposed to the browser by design — this
# is how Mapbox GL JS authenticates from the client. Do NOT use a secret token
# here; use a public (pk.*) token and restrict it with Mapbox URL restrictions
# (allowed referrers) and appropriate scopes. When this is unset, the map
# renders a graceful "Map unavailable" placeholder instead of failing.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=

# -----------------------------------------------------------------------------
# Local Firebase Emulator Suite (optional)
# Set to "true" to route the client and admin SDKs to the local emulators
# (ports defined in firebase.json: Firestore 8080, Auth 9099, Storage 9199).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false
NEXT_PUBLIC_FIREBASE_EMULATOR_HOST=127.0.0.1
# Server-side emulator toggle (defaults to NEXT_PUBLIC_USE_FIREBASE_EMULATOR):
FIREBASE_USE_EMULATOR=false
# When using emulators on the server, the admin SDK also honors these standard
# host variables (uncomment to use):
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199
